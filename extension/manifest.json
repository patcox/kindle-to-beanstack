{
  "manifest_version": 3,
  "name": "Kindle Reading → Beanstack",
  "version": "0.1.0",
  "description": "Pulls kids' Kindle/Amazon Kids+ reading activity from the Amazon Parent Dashboard and helps log it into a library's Beanstack reading challenge, with a human review step before anything is submitted.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://parents.amazon.com/*",
    "https://*.beanstack.com/*",
    "https://beanstackbooks.beanstack.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/parentdashboard/*"],
      "js": ["content-scripts/amazon.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.beanstack.com/*"],
      "js": ["content-scripts/beanstack-main-world.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.beanstack.com/*"],
      "js": ["content-scripts/beanstack.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/setup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*.js"],
      "matches": ["https://www.amazon.com/*", "https://*.beanstack.com/*"]
    }
  ]
}
